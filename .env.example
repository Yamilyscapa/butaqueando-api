# APP
APP_ENV=development
GIN_MODE=debug
PORT=3000

# DB
DATABASE_URL=postgres://postgres:postgres@localhost:5432/butaqueando?sslmode=disable
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m

# AUTH
JWT_ISSUER=butaqueando-api
JWT_ACCESS_SECRET=change-me-access-secret-32chars-min
JWT_REFRESH_SECRET=change-me-refresh-secret-32chars-min
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# EMAIL VERIFICATION
# Keep this true in production.
EMAIL_VERIFICATION_REQUIRED=true
EMAIL_VERIFICATION_REDIRECT_BASE=http://localhost:3000/verify-email
PASSWORD_RESET_REDIRECT_BASE=http://localhost:3000/reset-password
PASSWORD_RESET_TOKEN_TTL=1h

# RESEND (used for auth templates "login-code" and "reset-password")
RESEND_API_KEY=
RESEND_FROM_EMAIL=Butaqueando <noreply@example.com>
RESEND_TEMPLATE_LOGIN_CODE=login-code
RESEND_TEMPLATE_PASSWORD_RESET=reset-password
